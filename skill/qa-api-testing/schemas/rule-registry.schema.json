{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://empresa.example/schemas/rule-registry.schema.json",
  "title": "QA API Rule Registry",
  "type": "object",
  "required": ["api", "rules"],
  "properties": {
    "api": { "type": "string" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "operation", "condition", "source", "confidence"],
        "properties": {
          "id": { "type": "string" },
          "operation": { "type": "string" },
          "condition": { "type": "string" },
          "field": { "type": "string" },
          "status": { "type": "integer" },
          "message": { "type": "string" },
          "persistence": { "type": "string" },
          "source": { "type": "string" },
          "confidence": {
            "type": "string",
            "enum": ["Confirmada", "Provavel", "Indicio", "Nao confirmada"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
