{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://empresa.example/schemas/mass-map.schema.json",
  "title": "QA API Context And Mass Map",
  "type": "object",
  "required": ["api", "items"],
  "properties": {
    "api": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["need", "source", "setupStrategy", "cleanupStrategy"],
        "properties": {
          "need": { "type": "string" },
          "source": { "type": "string" },
          "setupStrategy": { "type": "string" },
          "cleanupStrategy": { "type": "string" },
          "confidence": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
